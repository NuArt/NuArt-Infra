# VZOR .env pro nový Next.js modul — BEZ HODNOT (jen názvy proměnných)
# Skutečný .env žije na serveru v /opt/stacks/<modul>/.env a je v .gitignore.
# NIKDY necommitovat skutečné hodnoty.

# --- Databáze (sdílený infra-postgres, dedikovaný uživatel per modul) ---
DATABASE_URL=
DIRECT_URL=

# --- Auth ---
# Better Auth (varianta backoffice):
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=          # https://modul.nuart.cz (veřejná doména, bez portu)
# Session-based (varianta CRM):
SESSION_SECRET=

# --- Integrace s CRM Core (moduly pod CRM identitou) ---
IDENTITY_DATABASE_URL=    # → crm_identity
CORE_URL=                 # → CRM core

# --- Path/host ---
BASE_PATH=                # např. /palety (path-based), prázdné pro root subdoménu
CRM_HOST=

# --- S3 / MinIO (infra-minio) ---
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=
S3_BUCKET=

# --- Iniciální admin (seed, dočasné — po prvním loginu změnit) ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
